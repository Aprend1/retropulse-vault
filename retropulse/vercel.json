{
  "version": 2,
  "builds": [
    {
      "src": "retropulse/wsgi.py",
      "use": "@vercel/python",
      "config": { "maxDuration": 90 }
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "retropulse/wsgi.py"
    }
  ]
}